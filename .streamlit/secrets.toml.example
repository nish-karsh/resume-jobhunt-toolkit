# Copy to .streamlit/secrets.toml for local secret storage, OR set these in your
# host's secret store (Hugging Face Space "Settings -> Variables and secrets").
# NEVER commit the real secrets.toml (it is gitignored).

# Required for AI tailoring / cover letters:
NVIDIA_API_KEY = "nvapi-your-key-here"

# Optional - gates the whole app behind a password (recommended for cloud):
app_password = "choose-a-strong-password"

# Optional - Adzuna job search (free keys at developer.adzuna.com):
ADZUNA_APP_ID = ""
ADZUNA_APP_KEY = ""

# Optional - SMTP for sending recruiter emails (otherwise .eml files are produced):
# SMTP_HOST = ""
# SMTP_PORT = "587"
# SMTP_USER = ""
# SMTP_PASS = ""
