% ATS-safe single-column resume (generated by Resume_Automate)
\documentclass[letterpaper,11pt]{article}

\usepackage[empty]{fullpage}
\usepackage{titlesec}
\usepackage{enumitem}
\usepackage[hidelinks]{hyperref}
\usepackage{fancyhdr}
\usepackage[english]{babel}
\usepackage{geometry}
\usepackage{xcolor}

\geometry{top=0.6in, bottom=0.6in, left=0.6in, right=0.6in}

\pagestyle{fancy}
\fancyhf{}
\fancyfoot{}
\renewcommand{\headrulewidth}{0pt}
\renewcommand{\footrulewidth}{0pt}

\urlstyle{same}
\raggedbottom
\raggedright
\setlength{\tabcolsep}{0in}

\titleformat{\section}{
  \vspace{-4pt}\scshape\raggedright\large
}{}{0em}{}[\color{black}\titlerule \vspace{-5pt}]

{% raw %}
\newcommand{\resumeItem}[1]{\item\small{#1 \vspace{-2pt}}}

\newcommand{\resumeSubheading}[4]{
  \vspace{-2pt}\item
    \begin{tabular*}{\textwidth}[t]{l@{\extracolsep{\fill}}r}
      \textbf{#1} & #2 \\
      \textit{\small#3} & \textit{\small #4} \\
    \end{tabular*}\vspace{-7pt}
}

\newcommand{\resumeProjectHeading}[2]{
    \item
    \begin{tabular*}{\textwidth}{l@{\extracolsep{\fill}}r}
      \small#1 & #2 \\
    \end{tabular*}\vspace{-7pt}
}

\renewcommand\labelitemii{$\vcenter{\hbox{\tiny$\bullet$}}$}
\newcommand{\resumeSubHeadingListStart}{\begin{itemize}[leftmargin=0.15in, label={}]}
\newcommand{\resumeSubHeadingListEnd}{\end{itemize}}
\newcommand{\resumeItemListStart}{\begin{itemize}}
\newcommand{\resumeItemListEnd}{\end{itemize}\vspace{-5pt}}
{% endraw %}

\begin{document}

\begin{center}
    {\Huge \scshape {{ (identity.name or 'Resume') | latex }}} \\ \vspace{4pt}
    \small
    {% if identity.email and identity.email != 'TODO' %}\href{mailto:{{ identity.email | latex_url }}}{ {{ identity.email | latex }} }{% endif %}
    {% if identity.phone and identity.phone != 'TODO' %} $|$ {{ identity.phone | latex }}{% endif %}
    {% if identity.location and identity.location != 'TODO' %} $|$ {{ identity.location | latex }}{% endif %}
    {% if identity.github %} $|$ \href{ {{ identity.github | latex_url }} }{ {{ identity.github | latex }} }{% endif %}
    {% if identity.linkedin %} $|$ \href{ {{ identity.linkedin | latex_url }} }{ {{ identity.linkedin | latex }} }{% endif %}
\end{center}

{% if summary %}
\section{Summary}
\small{ {{ summary | latex }} }
{% endif %}

{% if skills %}
\section{Skills}
\begin{itemize}[leftmargin=0.15in, label={}]
{% for category, items in skills.items() %}
  \item \small{\textbf{ {{ category | latex }}: } {{ items | join(', ') | latex }} }
{% endfor %}
\end{itemize}
\vspace{-5pt}
{% endif %}

{% if experience %}
\section{Experience}
\resumeSubHeadingListStart
{% for job in experience %}
  \resumeSubheading
    { {{ job.company | latex }} }{ {{ job.location | latex }} }
    { {{ job.title | latex }} }{ {{ job.start | latex }} -- {{ job.end | latex }} }
    {% if job.bullets %}
    \resumeItemListStart
    {% for bullet in job.bullets %}
      \resumeItem{ {{ bullet | latex }} }
    {% endfor %}
    \resumeItemListEnd
    {% endif %}
{% endfor %}
\resumeSubHeadingListEnd
{% endif %}

{% if projects %}
\section{Projects}
\resumeSubHeadingListStart
{% for project in projects %}
  \resumeProjectHeading
    {\textbf{ {{ project.name | latex }} }}{ {% if project.link %}\href{ {{ project.link | latex_url }} }{Link}{% endif %} }
    {% if project.bullets %}
    \resumeItemListStart
    {% for bullet in project.bullets %}
      \resumeItem{ {{ bullet | latex }} }
    {% endfor %}
    \resumeItemListEnd
    {% endif %}
{% endfor %}
\resumeSubHeadingListEnd
{% endif %}

{% if education %}
\section{Education}
\resumeSubHeadingListStart
{% for edu in education %}
  \resumeSubheading
    { {{ edu.institution | latex }} }{ {{ edu.location | latex }} }
    { {{ edu.degree | latex }}{% if edu.field %} \textbar{} {{ edu.field | latex }}{% endif %}{% if edu.gpa %} \textbar{} CGPA: {{ edu.gpa | latex }}{% endif %} }
    { {{ edu.start | latex }} -- {{ edu.end | latex }} }
{% endfor %}
\resumeSubHeadingListEnd
{% endif %}

{% if certifications %}
\section{Certifications}
\begin{itemize}[leftmargin=0.15in, label={}]
{% for cert in certifications %}
  \item \small{ {{ cert | latex }} }
{% endfor %}
\end{itemize}
\vspace{-5pt}
{% endif %}

\end{document}
